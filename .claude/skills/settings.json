{
  "permissions": {
    "deny": [
      "Read(./node_modules/**)",
      "Read(target/node_modules/**)",
      "Read(target/dist/**)",
      "Read(target/build/**)",
      "Read(target/.next/**)",
      "Read(target/package-lock.json)",
      "Read(target/yarn.lock)",
      "Read(target/pnpm-lock.yaml)",
      "Read(target/.env)",
      "Read(target/.env.*)",
      "Read(target/secrets/**)",
      "Read(target/config/credentials.json)",
      "Read(target/public/images/**)",
      "Read(target/public/assets/**)",
      "Read(target/**/*.log)",
      "Read(target/**/*.generated.ts)"
    ]
  }
}
